def db_request(endpoint,data):
    try:
        resp = requests.post(f"{db_url}/{endpoint}",json=data)
        if resp.status_code != 200:
            st.error(f"API error {resp.status_code}:{resp.text}")
            return False,None
        return resp.status_code==200, resp.json()
    except Exception as e:
        st.error(f"Database API error: {str(e)}")
        return False,None


