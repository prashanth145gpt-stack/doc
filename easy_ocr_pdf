@app.post("/ocr/process")
async def ocr_process(
    file: UploadFile = File(...),
    mode: Mode = Query(Mode.full, description="Output formatting: full | compact | tables")
):
    start = time.time()

    ext = (file.filename.split(".")[-1].lower() if file.filename else "")
    if ext != "pdf":
        return JSONResponse({"status": "failure", "reason": "Only PDF files are accepted (scanned PDFs)."}, status_code=400)

    raw = await file.read()
    try:
        pages = rasterize_pdf(raw, dpi=DPI)
    except Exception as e:
        return JSONResponse({"status": "failure", "reason": f"PDF decoding failed: {e}"}, status_code=400)

    page_results: List[PageResult] = []

    # Process pages sequentially (safe & simple for MVP). You can parallelize later.
    for idx, pil_img in enumerate(pages):
        metrics = quality_check_scan(pil_img)
        if not metrics.ok:
            page_results.append(PageResult(page_index=idx, metrics=metrics, tokens=[], blocks=[]))
            continue

        text_bgr, table_bgr, _ = preprocess_for_ocr(pil_img, metrics.skew_deg)

        # OCR
        tokens = easyocr_tokens(text_bgr)

        # Layout
        blocks = build_blocks_from_tokens(tokens, table_bgr)

        page_results.append(PageResult(page_index=idx, metrics=metrics, tokens=tokens, blocks=blocks))

        # housekeeping
        gc.collect()

    # Render text (Markdown-styled) and stream as .txt
    txt = render_markdown_txt(file.filename, page_results, mode=mode)

    mem = io.BytesIO(txt.encode("utf-8"))
    mem.seek(0)
    # Set a filename that includes mode
    out_name = DEFAULT_OUT_NAME
    if out_name.endswith(".txt"):
        base = out_name[:-4]
        out_name = f"{base}_{mode.value}.txt"

    headers = {
        "Content-Disposition": f'attachment; filename="{out_name}"'
    }
    took = time.time() - start
    headers["X-Processing-Time-ms"] = str(int(1000 * took))

    return StreamingResponse(mem, media_type="text/plain; charset=utf-8", headers=headers)


