import cv2, numpy as np, re, fitz
from paddleocr import PaddleOCR, PPStructure

ocr = PaddleOCR(use_angle_cls=True, lang="en", show_log=False)
layout_engine = PPStructure(show_log=False)

def pdf_to_images(pdf_path):
    doc = fitz.open(pdf_path)
    images=[]
    for page in doc:
        pix=page.get_pixmap(dpi=300)
        img=np.frombuffer(pix.samples,dtype=np.uint8).reshape(pix.h,pix.w,pix.n)
        if pix.n==4: img=cv2.cvtColor(img,cv2.COLOR_BGRA2BGR)
        images.append(img)
    return images

def readable_page(img):
    result=ocr.ocr(img,rec=False)
    if not result or not result[0]: return False
    boxes=result[0]
    if len(boxes)<3: return False
    areas=[]
    for box in boxes:
        xs=[p[0] for p in box]; ys=[p[1] for p in box]
        w=max(xs)-min(xs); h=max(ys)-min(ys)
        areas.append(w*h)
    return np.mean(areas)>500

def quality_check(img):
    gray=cv2.cvtColor(img,cv2.COLOR_BGR2GRAY)
    blur=cv2.Laplacian(gray,cv2.CV_64F).var()
    brightness=np.mean(gray)
    contrast=gray.std()
    if blur<50 or brightness<40 or brightness>220 or contrast<30: return False
    if not readable_page(img): return False
    return True

def auto_rotate(img):
    gray=cv2.cvtColor(img,cv2.COLOR_BGR2GRAY)
    edges=cv2.Canny(gray,50,150)
    lines=cv2.HoughLines(edges,1,np.pi/180,200)
    if lines is None: return img
    angles=[(theta*180/np.pi)-90 for rho,theta in lines[:,0]]
    angle=np.median(angles)
    h,w=img.shape[:2]
    M=cv2.getRotationMatrix2D((w//2,h//2),angle,1)
    return cv2.warpAffine(img,M,(w,h))

def remove_shadow(img):
    gray=cv2.cvtColor(img,cv2.COLOR_BGR2GRAY)
    dilated=cv2.dilate(gray,np.ones((7,7),np.uint8))
    bg=cv2.medianBlur(dilated,21)
    diff=255-cv2.absdiff(gray,bg)
    return cv2.normalize(diff,None,0,255,cv2.NORM_MINMAX)

def remove_lines(img):
    thresh=cv2.adaptiveThreshold(img,255,cv2.ADAPTIVE_THRESH_MEAN_C,cv2.THRESH_BINARY_INV,15,10)
    h=cv2.getStructuringElement(cv2.MORPH_RECT,(40,1))
    v=cv2.getStructuringElement(cv2.MORPH_RECT,(1,40))
    mask=cv2.add(cv2.morphologyEx(thresh,cv2.MORPH_OPEN,h),cv2.morphologyEx(thresh,cv2.MORPH_OPEN,v))
    cleaned=cv2.subtract(thresh,mask)
    return cv2.bitwise_not(cleaned)

def structure_text(lines):
    num_pattern=r"\d{1,3}(?:,\d{3})*(?:\.\d+)"
    out=[]
    for line in lines:
        nums=re.findall(num_pattern,line)
        if len(nums)>=2:
            text=re.sub(num_pattern,"",line).strip()
            out.append(text)
            out.append(f"Value1: {nums[0]}")
            out.append(f"Value2: {nums[1]}")
        else: out.append(line)
    return "\n".join(out)

def process_page(img):
    img=auto_rotate(img)
    img=remove_shadow(img)
    img=remove_lines(img)
    layout=layout_engine(img)
    page_text=""
    tb,tc=1,1
    for block in layout:
        if block["type"]=="table":
            page_text+=f"\nTABLE {tc}\n"
            if "res" in block: page_text+=str(block["res"])
            page_text+="\n"
            tc+=1
        elif block["type"]=="text":
            crop=block["img"]
            result=ocr.ocr(crop)
            if not result or not result[0]: continue
            result=sorted(result[0],key=lambda x:x[0][0][1])
            lines=[l[1][0] for l in result]
            structured=structure_text(lines)
            page_text+=f"\nTEXT {tb}\n{structured}\n"
            tb+=1
    return page_text

def process_pdf(pdf_path):
    pages=pdf_to_images(pdf_path)
    doc_text=""
    for i,img in enumerate(pages):
        if not quality_check(img): continue
        page_text=process_page(img)
        doc_text+=f"\nPAGE {i+1}\n{page_text}"
    return doc_text

if __name__=="__main__":
    pdf="input.pdf"
    text=process_pdf(pdf)
    print(text)
