# Data structures
# =========================
@dataclass
class Token:
    text: str
    conf: float
    # Axis-aligned bbox (x0, y0, x1, y1) in px
    x0: float
    y0: float
    x1: float
    y1: float
    # Derived
    cx: float
    cy: float
    h: float


@dataclass
class PageMetrics:
    width: int
    height: int
    blur_var: float
    contrast_std: float
    skew_deg: float
    ok: bool
    failure_code: Optional[str] = None
    reason: Optional[str] = None


@dataclass
class PageResult:
    page_index: int
    metrics: PageMetrics
    tokens: List[Token]
    blocks: List[Dict[str, Any]]  # heading/paragraph/kv/table blocks


